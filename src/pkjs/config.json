            },
            {
                "type": "toggle",
                "messageKey": "CONFIRM_TRANSCRIPTS",
                "defaultValue": false,
                "label": "Confirm prompts before responding",
                "description": "When enabled, after dictating to the watch, you'll always be asked to confirm your input before Squire takes action. When disabled, Squire will respond immediately to whatever was recognised."
